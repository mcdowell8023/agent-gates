#!/usr/bin/env bash
# agent-gates-review — capability-aware cross-review router.
#
# Reads ~/.agent-gates/review-capability.json to determine the machine's review
# capability level (L0-L3), then routes to the best available heterogeneous tool.
#
# Usage:  agent-gates-review <prompt-file> [--result <result-file>]
#
# Routing:
#   L3 (opencode+codex): oc-review (opencode) → fallback codex
#   L2 (opencode):       oc-review (opencode) → exit 75
#   L1 (codex/omc):      codex exec            → exit 75
#   L0 (none):           exit 78 + warning (same-model only)
#
# Exit codes:
#   0   review completed with heterogeneous tool
#   69  not installed (no review-capability.json)
#   75  review tool failed (caller should fall back to agent-tool)
#   78  L0 machine — no heterogeneous tool available
#
# Env:
#   AGENT_GATES_DIR       override ~/.agent-gates
#   OC_REVIEW_OPENCODE    opencode binary (passed to oc-review)
#   OC_REVIEW_RETRIES     oc-review retry count
#   AG_REVIEW_CODEX       codex binary (default "codex")
#   AG_REVIEW_MODEL       opencode model (default "github-copilot/gpt-5.5")
#
# Source: https://github.com/mcdowell8023/agent-gates
set -uo pipefail

GATES_DIR="${AGENT_GATES_DIR:-$HOME/.agent-gates}"
CAP_FILE="$GATES_DIR/review-capability.json"
CODEX="${AG_REVIEW_CODEX:-codex}"
MODEL="${AG_REVIEW_MODEL:-github-copilot/gpt-5.5}"

PROMPT_FILE=""
RESULT_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --result) [[ $# -ge 2 ]] || { echo "agent-gates-review: --result requires a path" >&2; exit 1; }; RESULT_FILE="$2"; shift 2 ;;
    *)
      if [[ -z "$PROMPT_FILE" ]]; then PROMPT_FILE="$1"; shift
      else echo "agent-gates-review: unknown arg: $1" >&2; exit 1; fi ;;
  esac
done

if [[ -z "$PROMPT_FILE" || ! -f "$PROMPT_FILE" ]]; then
  echo "Usage: agent-gates-review <prompt-file> [--result <result-file>]" >&2
  exit 1
fi

if [[ ! -f "$CAP_FILE" ]]; then
  echo "agent-gates-review: review-capability.json not found at $CAP_FILE — run install.sh or doctor.sh first" >&2
  exit 69
fi

LEVEL=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['level'])" "$CAP_FILE" 2>/dev/null || echo "L0")
PREFERRED=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['preferred_route'])" "$CAP_FILE" 2>/dev/null || echo "agent-tool")
FALLBACK=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('fallback_route','agent-tool'))" "$CAP_FILE" 2>/dev/null || echo "agent-tool")

PROMPT_CONTENT="$(cat "$PROMPT_FILE")"

append_marker() {
  local tool="$1" model="$2" content="$3"
  printf '%s\n\n<!-- REVIEW_TOOL: %s -->\n<!-- REVIEW_MODEL: %s -->\n<!-- REVIEW_LEVEL: %s -->\n' "$content" "$tool" "$model" "$LEVEL"
}

output_result() {
  local content="$1"
  if [[ -n "$RESULT_FILE" ]]; then
    echo "$content" > "$RESULT_FILE"
  else
    echo "$content"
  fi
}

run_opencode() {
  local opencode_bin="${OC_REVIEW_OPENCODE:-opencode}"
  local oc_review="$GATES_DIR/bin/oc-review"

  local raw rc
  if [[ -x "$oc_review" && -z "${OC_REVIEW_OPENCODE:-}" ]]; then
    raw=$("$oc_review" run -m "$MODEL" --dir "${PWD}" --format json "$PROMPT_CONTENT" 2>/dev/null)
    rc=$?
  else
    raw=$("$opencode_bin" run -m "$MODEL" --dir "${PWD}" --format json "$PROMPT_CONTENT" 2>/dev/null)
    rc=$?
  fi

  if [[ $rc -eq 0 ]] && [[ -n "$raw" ]] && echo "$raw" | grep -q '[^[:space:]]'; then
    local result
    result=$(append_marker "opencode" "$MODEL" "$raw")
    output_result "$result"
    return 0
  fi
  return 1
}

run_codex() {
  local raw
  raw=$("$CODEX" exec -s read-only --skip-git-repo-check -C "${PWD}" < "$PROMPT_FILE" 2>/dev/null)
  local rc=$?
  if [[ $rc -eq 0 && -n "$raw" ]]; then
    local result
    result=$(append_marker "codex" "gpt-5-series" "$raw")
    output_result "$result"
    return 0
  fi
  return 1
}

case "$LEVEL" in
  L3)
    if run_opencode; then exit 0; fi
    echo "agent-gates-review: opencode failed, falling back to codex" >&2
    if run_codex; then exit 0; fi
    echo "agent-gates-review: both opencode and codex failed" >&2
    exit 75
    ;;
  L2)
    if run_opencode; then exit 0; fi
    echo "agent-gates-review: opencode failed (L2, no codex fallback)" >&2
    exit 75
    ;;
  L1)
    if run_codex; then exit 0; fi
    echo "agent-gates-review: codex failed (L1)" >&2
    exit 75
    ;;
  L0|*)
    echo "agent-gates-review: L0 machine — no heterogeneous review tool available. Same-model degraded review only." >&2
    echo "  Install opencode (https://opencode.ai) or codex (npm i -g @openai/codex) to unlock L1+." >&2
    exit 78
    ;;
esac
